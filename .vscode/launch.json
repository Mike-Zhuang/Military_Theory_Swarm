{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sim: Compare Export",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/sim-core/simulate.py",
      "cwd": "${workspaceFolder}/sim-core",
      "args": [
        "--compare",
        "--scenario",
        "jam-recovery",
        "--steps",
        "260",
        "--agents",
        "32",
        "--packet-loss",
        "0.25",
        "--output",
        "../web-demo/public/generated/demo-compare.json"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Sim: Generate Scenario Pack",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/sim-core/generate_scenario_pack.py",
      "cwd": "${workspaceFolder}/sim-core",
      "args": [
        "--steps",
        "220",
        "--agents",
        "28",
        "--packet-loss",
        "0.22"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Sim: Experiment Matrix",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/sim-core/run_experiments.py",
      "cwd": "${workspaceFolder}/sim-core",
      "args": [
        "--steps",
        "180",
        "--agents",
        "24",
        "--output-dir",
        "../docs/outputs"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "ML: Prepare VisDrone (Official Val)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/ml-module/data/prepare_visdrone.py",
      "cwd": "${workspaceFolder}/ml-module",
      "args": [
        "--split-mode",
        "official-val",
        "--raw-dir",
        "data/visdrone/raw",
        "--train-images-dir",
        "data/visdrone/raw/VisDrone2019-DET-train/images",
        "--train-annotations-dir",
        "data/visdrone/raw/VisDrone2019-DET-train/annotations",
        "--val-images-dir",
        "data/visdrone/raw/VisDrone2019-DET-val/images",
        "--val-annotations-dir",
        "data/visdrone/raw/VisDrone2019-DET-val/annotations",
        "--output-dir",
        "data/visdrone-ready",
        "--subset-size-per-class",
        "900",
        "--val-subset-size-per-class",
        "0"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "ML: Train Tiny CNN",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/ml-module/train.py",
      "cwd": "${workspaceFolder}/ml-module",
      "args": [
        "--data-dir",
        "data/visdrone-ready",
        "--epochs",
        "18",
        "--batch-size",
        "64",
        "--output",
        "runs/dev/checkpoints/tiny-cnn.pt"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "ML: Infer and Export Class Confidence",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/ml-module/infer.py",
      "cwd": "${workspaceFolder}/ml-module",
      "args": [
        "--checkpoint",
        "runs/dev/checkpoints/tiny-cnn.pt",
        "--calibration-dir",
        "data/visdrone-ready/val",
        "--emit-class-confidence",
        "../sim-core/class-confidence.json"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "ML: Evaluate Validation Set",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/ml-module/evaluate.py",
      "cwd": "${workspaceFolder}/ml-module",
      "args": [
        "--checkpoint",
        "runs/dev/checkpoints/tiny-cnn.pt",
        "--data-dir",
        "data/visdrone-ready",
        "--split",
        "val",
        "--output-dir",
        "runs/dev/eval"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Docs: Plot Metrics",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/docs/plot_metrics.py",
      "cwd": "${workspaceFolder}/docs",
      "args": [
        "--csv",
        "outputs/experiment-matrix.csv",
        "--output-dir",
        "outputs/figures"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}",
      "args": [
        "backend.app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8001",
        "--reload"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Web: Static Server",
      "type": "debugpy",
      "request": "launch",
      "module": "http.server",
      "cwd": "${workspaceFolder}",
      "args": [
        "5173",
        "--directory",
        "web-demo"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Web: Open Demo",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web-demo"
    }
  ],
  "compounds": [
    {
      "name": "Demo: Serve and Open",
      "configurations": [
        "Backend: FastAPI",
        "Web: Static Server",
        "Web: Open Demo"
      ]
    }
  ]
}
