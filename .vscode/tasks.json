{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sim: export compare scenario",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "simulate.py",
        "--compare",
        "--scenario",
        "jam-recovery",
        "--steps",
        "260",
        "--agents",
        "32",
        "--packet-loss",
        "0.25",
        "--output",
        "../web-demo/public/generated/demo-compare.json"
      ],
      "options": {
        "cwd": "${workspaceFolder}/sim-core"
      },
      "group": "build"
    },
    {
      "label": "sim: generate scenario pack",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "generate_scenario_pack.py",
        "--steps",
        "220",
        "--agents",
        "28",
        "--packet-loss",
        "0.22"
      ],
      "options": {
        "cwd": "${workspaceFolder}/sim-core"
      },
      "group": "build"
    },
    {
      "label": "sim: run experiment matrix",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "run_experiments.py",
        "--steps",
        "180",
        "--agents",
        "24",
        "--output-dir",
        "../docs/outputs"
      ],
      "options": {
        "cwd": "${workspaceFolder}/sim-core"
      },
      "group": "build"
    },
    {
      "label": "ml: prepare visdrone official-val",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "data/prepare_visdrone.py",
        "--split-mode",
        "official-val",
        "--raw-dir",
        "data/visdrone/raw",
        "--train-images-dir",
        "data/visdrone/raw/VisDrone2019-DET-train/images",
        "--train-annotations-dir",
        "data/visdrone/raw/VisDrone2019-DET-train/annotations",
        "--val-images-dir",
        "data/visdrone/raw/VisDrone2019-DET-val/images",
        "--val-annotations-dir",
        "data/visdrone/raw/VisDrone2019-DET-val/annotations",
        "--output-dir",
        "data/visdrone-ready",
        "--subset-size-per-class",
        "900",
        "--val-subset-size-per-class",
        "0"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ml-module"
      },
      "group": "build"
    },
    {
      "label": "ml: train tiny cnn",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "train.py",
        "--data-dir",
        "data/visdrone-ready",
        "--epochs",
        "18",
        "--batch-size",
        "64",
        "--output",
        "runs/dev/checkpoints/tiny-cnn.pt"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ml-module"
      },
      "group": "build"
    },
    {
      "label": "ml: export class confidence",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "infer.py",
        "--checkpoint",
        "runs/dev/checkpoints/tiny-cnn.pt",
        "--calibration-dir",
        "data/visdrone-ready/val",
        "--emit-class-confidence",
        "../sim-core/class-confidence.json"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ml-module"
      },
      "group": "build"
    },
    {
      "label": "ml: evaluate validation set",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "evaluate.py",
        "--checkpoint",
        "runs/dev/checkpoints/tiny-cnn.pt",
        "--data-dir",
        "data/visdrone-ready",
        "--split",
        "val",
        "--output-dir",
        "runs/dev/eval"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ml-module"
      },
      "group": "build"
    },
    {
      "label": "docs: plot metrics",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "plot_metrics.py",
        "--csv",
        "outputs/experiment-matrix.csv",
        "--output-dir",
        "outputs/figures"
      ],
      "options": {
        "cwd": "${workspaceFolder}/docs"
      },
      "group": "build"
    },
    {
      "label": "backend: serve api",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "uvicorn",
        "backend.app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8001",
        "--reload"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "web: serve demo",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "http.server",
        "5173",
        "--directory",
        "web-demo"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
